#include <onnxruntime_cxx_api.h>

#include <algorithm>
#include <cstdlib>
#include <fstream>
#include <iostream>
#include <numeric>
#include <random>
#include <string>
#include <vector>

static const char* detect_arch() {
#if defined(__aarch64__)
    return "aarch64";
#elif defined(__x86_64__)
    return "x86_64";
#elif defined(__arm__)
    return "arm";
#else
    return "unknown";
#endif
}

static int64_t normalize_dim(int64_t dim) {
    if (dim <= 0) {
        return 1;
    }
    return dim;
}

static bool load_float32_binary(
    const std::string& input_path,
    std::vector<float>& input_data
) {
    std::ifstream file(input_path, std::ios::binary | std::ios::ate);
    if (!file) {
        std::cerr << "[ERROR] Cannot open input tensor: " << input_path << std::endl;
        return false;
    }

    std::streamsize byte_size = file.tellg();
    file.seekg(0, std::ios::beg);

    const std::streamsize expected_bytes =
        static_cast<std::streamsize>(input_data.size() * sizeof(float));
    if (byte_size != expected_bytes) {
        std::cerr << "[ERROR] Input tensor byte size mismatch." << std::endl;
        std::cerr << "[ERROR] Expected bytes: " << expected_bytes
                  << ", actual bytes: " << byte_size << std::endl;
        return false;
    }

    if (!file.read(reinterpret_cast<char*>(input_data.data()), byte_size)) {
        std::cerr << "[ERROR] Failed to read input tensor: " << input_path << std::endl;
        return false;
    }

    return true;
}

int main(int argc, char** argv) {
    std::string model_path = "./{{ model_name }}";
    std::string input_path;

    if (argc >= 2) {
        model_path = argv[1];
    }
    if (argc >= 3) {
        input_path = argv[2];
    }

    std::cout << "====================================" << std::endl;
    std::cout << " EdgeAI ONNX Runtime Inference Demo" << std::endl;
    std::cout << "====================================" << std::endl;
    std::cout << "Build architecture: " << detect_arch() << std::endl;
    std::cout << "Model path: " << model_path << std::endl;
    if (!input_path.empty()) {
        std::cout << "Input tensor path: " << input_path << std::endl;
    }

    try {
        Ort::Env env(ORT_LOGGING_LEVEL_WARNING, "edgeai");
        Ort::SessionOptions session_options;
        session_options.SetIntraOpNumThreads(1);
        session_options.SetGraphOptimizationLevel(GraphOptimizationLevel::ORT_ENABLE_BASIC);

        Ort::Session session(env, model_path.c_str(), session_options);
        Ort::AllocatorWithDefaultOptions allocator;

        size_t input_count = session.GetInputCount();
        size_t output_count = session.GetOutputCount();

        std::cout << "Input count: " << input_count << std::endl;
        std::cout << "Output count: " << output_count << std::endl;

        if (input_count == 0 || output_count == 0) {
            std::cerr << "[ERROR] Invalid model: no input or output." << std::endl;
            return 1;
        }

        auto input_name_alloc = session.GetInputNameAllocated(0, allocator);
        auto output_name_alloc = session.GetOutputNameAllocated(0, allocator);

        const char* input_name = input_name_alloc.get();
        const char* output_name = output_name_alloc.get();

        std::cout << "Input name: " << input_name << std::endl;
        std::cout << "Output name: " << output_name << std::endl;

        Ort::TypeInfo input_type_info = session.GetInputTypeInfo(0);
        auto input_tensor_info = input_type_info.GetTensorTypeAndShapeInfo();

        ONNXTensorElementDataType input_type = input_tensor_info.GetElementType();
        if (input_type != ONNX_TENSOR_ELEMENT_DATA_TYPE_FLOAT) {
            std::cerr << "[ERROR] This demo currently only supports float32 input." << std::endl;
            std::cerr << "[ERROR] Input element type code: " << input_type << std::endl;
            return 1;
        }

        std::vector<int64_t> input_shape = input_tensor_info.GetShape();

        std::cout << "Input shape:";
        for (auto& dim : input_shape) {
            dim = normalize_dim(dim);
            std::cout << " " << dim;
        }
        std::cout << std::endl;

        size_t input_tensor_size = 1;
        for (auto dim : input_shape) {
            input_tensor_size *= static_cast<size_t>(dim);
        }

        std::vector<float> input_data(input_tensor_size);

        if (!input_path.empty()) {
            if (!load_float32_binary(input_path, input_data)) {
                return 1;
            }
            std::cout << "[INFO] Loaded input tensor from file." << std::endl;
        } else {
            std::mt19937 gen(42);
            std::uniform_real_distribution<float> dist(0.0f, 1.0f);
            for (auto& v : input_data) {
                v = dist(gen);
            }
            std::cout << "[INFO] Using random input tensor." << std::endl;
        }

        Ort::MemoryInfo memory_info = Ort::MemoryInfo::CreateCpu(
            OrtArenaAllocator,
            OrtMemTypeDefault
        );

        Ort::Value input_tensor = Ort::Value::CreateTensor<float>(
            memory_info,
            input_data.data(),
            input_data.size(),
            input_shape.data(),
            input_shape.size()
        );

        std::vector<const char*> input_names = {input_name};
        std::vector<const char*> output_names = {output_name};

        std::cout << "[INFO] Running inference..." << std::endl;

        auto output_tensors = session.Run(
            Ort::RunOptions{nullptr},
            input_names.data(),
            &input_tensor,
            1,
            output_names.data(),
            1
        );

        if (output_tensors.empty()) {
            std::cerr << "[ERROR] No output tensor returned." << std::endl;
            return 1;
        }

        auto output_info = output_tensors[0].GetTensorTypeAndShapeInfo();
        auto output_shape = output_info.GetShape();

        std::cout << "Output shape:";
        for (auto dim : output_shape) {
            std::cout << " " << dim;
        }
        std::cout << std::endl;

        ONNXTensorElementDataType output_type = output_info.GetElementType();
        if (output_type == ONNX_TENSOR_ELEMENT_DATA_TYPE_FLOAT) {
            float* output_data = output_tensors[0].GetTensorMutableData<float>();
            size_t output_count_values = output_info.GetElementCount();

            std::cout << "Output sample:";
            size_t show_count = std::min<size_t>(10, output_count_values);
            for (size_t i = 0; i < show_count; ++i) {
                std::cout << " " << output_data[i];
            }
            std::cout << std::endl;

            if (output_count_values > 0) {
                size_t top1 = 0;
                for (size_t i = 1; i < output_count_values; ++i) {
                    if (output_data[i] > output_data[top1]) {
                        top1 = i;
                    }
                }
                std::cout << "Top1 index: " << top1 << std::endl;
                std::cout << "Top1 value: " << output_data[top1] << std::endl;
            }
        } else {
            std::cout << "[WARN] Output is not float32. Output element type code: "
                      << output_type << std::endl;
        }

        std::cout << "[INFO] Inference finished successfully." << std::endl;
        return 0;

    } catch (const Ort::Exception& e) {
        std::cerr << "[ONNXRuntime ERROR] " << e.what() << std::endl;
        return 1;
    } catch (const std::exception& e) {
        std::cerr << "[STD ERROR] " << e.what() << std::endl;
        return 1;
    }
}
