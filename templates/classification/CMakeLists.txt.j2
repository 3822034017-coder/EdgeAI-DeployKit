cmake_minimum_required(VERSION 3.10)

project(edgeai_ort_infer_demo LANGUAGES CXX)

set(CMAKE_CXX_STANDARD 17)
set(CMAKE_CXX_STANDARD_REQUIRED ON)

if(NOT DEFINED ONNXRUNTIME_ROOT)
    message(FATAL_ERROR "Please set -DONNXRUNTIME_ROOT=/path/to/onnxruntime-aarch64")
endif()

include_directories(${ONNXRUNTIME_ROOT}/include)
link_directories(${ONNXRUNTIME_ROOT}/lib)

add_executable(arm64_infer infer.cpp)

target_link_libraries(
    arm64_infer
    onnxruntime
    m
    dl
    pthread
)

target_compile_options(arm64_infer PRIVATE -Wall -Wextra)
